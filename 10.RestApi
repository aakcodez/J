2. Code Files


---

File 1: StudentResource.java

package com.student.api;

import java.util.HashMap;
import java.util.Map;
import javax.ws.rs.*;
import javax.ws.rs.core.MediaType;

@Path("/students")
public class StudentResource {

    private static Map<String, String> studentDB = new HashMap<>();

    static {
        studentDB.put("101", "John Doe");
        studentDB.put("102", "Jane Smith");
    }

    // Helper method to return HTML
    private String html(String message) {
        return "<html><body><h3>" + message + "</h3></body></html>";
    }

    // GET - List Students
    @GET
    @Path("/list")
    @Produces(MediaType.TEXT_HTML)
    public String getAllStudents() {

        if(studentDB.isEmpty())
            return html("No students found");

        String list = studentDB.entrySet()
                .stream()
                .map(e -> "ID: " + e.getKey() + " Name: " + e.getValue())
                .reduce((a,b) -> a + "<br>" + b)
                .orElse("");

        return html(list);
    }

    // POST - Add Student
    @POST
    @Path("/create")
    @Produces(MediaType.TEXT_HTML)
    public String addStudent(@QueryParam("id") String id,
                             @QueryParam("name") String name) {

        if(id == null || name == null)
            return html("Error: Provide ID and Name");

        studentDB.put(id, name);

        return html("Student Added : " + name + " (ID : " + id + ")");
    }

    // PUT - Update Student
    @PUT
    @Path("/update")
    @Produces(MediaType.TEXT_HTML)
    public String updateStudent(@QueryParam("id") String id,
                                @QueryParam("name") String name) {

        if(!studentDB.containsKey(id))
            return html("Error: Student ID not found");

        studentDB.put(id, name);

        return html("Student " + id + " Updated to : " + name);
    }

    // DELETE - Delete Student
    @DELETE
    @Path("/delete/{id}")
    @Produces(MediaType.TEXT_HTML)
    public String deleteStudent(@PathParam("id") String id) {

        if(!studentDB.containsKey(id))
            return html("Error: Student ID not found");

        String name = studentDB.remove(id);

        return html("Student Removed : " + name + " (ID : " + id + ")");
    }
}


---

File 2: web.xml

Location:

WebContent → WEB-INF → web.xml

<?xml version="1.0" encoding="UTF-8"?>

<web-app xmlns="http://java.sun.com/xml/ns/javaee"
         version="3.0">

<servlet>
    <servlet-name>Jersey</servlet-name>

    <servlet-class>
        com.sun.jersey.spi.container.servlet.ServletContainer
    </servlet-class>

    <init-param>
        <param-name>
        com.sun.jersey.config.property.packages
        </param-name>

        <param-value>
        com.student.api
        </param-value>

    </init-param>

    <load-on-startup>1</load-on-startup>

</servlet>

<servlet-mapping>
    <servlet-name>Jersey</servlet-name>
    <url-pattern>/rest/*</url-pattern>
</servlet-mapping>

</web-app>


